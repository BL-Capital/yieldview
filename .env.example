# YieldField — Environment Variables Template
# Copy to .env.local for local development (never commit .env.local)
# In production, set via GitHub Actions Secrets (pipeline) and Cloudflare Pages (frontend)

# ── Data Pipeline (GitHub Actions Secrets) ──────────────────────────────────

# Finnhub API key — primary market data source (VIX, indices, DXY)
# Free tier: 60 req/min — https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# FRED API key — US/EU sovereign rates (OAT 10Y, Bund 10Y, US 10Y)
# Free tier: unlimited — https://fred.stlouisfed.org/docs/api/fred/
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage API key — marginal data source (25 req/day free tier)
# https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Anthropic API key — Claude Opus (FR briefing) + Claude Haiku (EN translation)
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cloudflare R2 credentials — S3-compatible storage for pipeline output
# Create in Cloudflare dashboard > R2 > Manage R2 API tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=yieldfield-content
R2_ACCOUNT_ID=your_cloudflare_account_id_here

# Buttondown API key — newsletter distribution
# https://buttondown.email/settings/programming
BUTTONDOWN_API_KEY=your_buttondown_api_key_here

# ── Frontend (Cloudflare Pages env vars) ────────────────────────────────────

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yieldfield.io

# Cloudflare Web Analytics token (public, safe to expose)
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your_cf_analytics_token_here

# R2 public URL for reading latest.json
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-url.r2.cloudflarestorage.com
