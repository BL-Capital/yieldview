#!/bin/bash
# Pre-commit hook: detect secrets, API keys, passwords, tokens
# Blocks commit if sensitive data is found in staged files

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Patterns to detect
PATTERNS=(
    # API Keys & Tokens
    'AKIA[0-9A-Z]{16}'                          # AWS Access Key
    '['\''"]sk-[a-zA-Z0-9]{20,}['\''"]'         # OpenAI / Stripe secret key
    'ghp_[a-zA-Z0-9]{36}'                       # GitHub personal access token
    'gho_[a-zA-Z0-9]{36}'                       # GitHub OAuth token
    'github_pat_[a-zA-Z0-9_]{22,}'              # GitHub fine-grained PAT
    'xox[bporas]-[a-zA-Z0-9-]+'                 # Slack token
    'sk-ant-[a-zA-Z0-9-]{20,}'                  # Anthropic API key
    'AIza[0-9A-Za-z_-]{35}'                     # Google API key

    # Generic secrets
    '[pP][aA][sS][sS][wW][oO][rR][dD]\s*[=:]\s*['\''"][^'\''"]{4,}['\''"]'
    '[sS][eE][cC][rR][eE][tT]\s*[=:]\s*['\''"][^'\''"]{4,}['\''"]'
    '[tT][oO][kK][eE][nN]\s*[=:]\s*['\''"][^'\''"]{4,}['\''"]'
    '[aA][pP][iI]_?[kK][eE][yY]\s*[=:]\s*['\''"][^'\''"]{4,}['\''"]'

    # Private keys
    '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'

    # Connection strings
    'mongodb(\+srv)?://[^\s]+'
    'postgres(ql)?://[^\s]+'
    'mysql://[^\s]+'
    'redis://[^\s]+'

    # .env content patterns
    'DB_PASSWORD\s*='
    'DATABASE_URL\s*=\s*['\''"]?[a-zA-Z]+://'
    'SMTP_PASSWORD\s*='
)

# Files to ignore
IGNORE_FILES='\.git/|node_modules/|\.lock$|package-lock\.json|\.sample$|scripts/pre-commit$'

found=0
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$staged_files" ]; then
    exit 0
fi

for file in $staged_files; do
    # Skip ignored files
    if echo "$file" | grep -qE "$IGNORE_FILES"; then
        continue
    fi

    # Check if .env file is being committed (allow .env.example and .env.sample — templates)
    if echo "$file" | grep -qE '\.env($|\.)' && ! echo "$file" | grep -qE '\.env\.(example|sample|template)$'; then
        echo -e "${RED}BLOCKED:${NC} .env file detected: $file"
        echo "  -> Add it to .gitignore instead"
        found=1
        continue
    fi

    content=$(git show ":$file" 2>/dev/null)
    if [ -z "$content" ]; then
        continue
    fi

    for pattern in "${PATTERNS[@]}"; do
        matches=$(echo "$content" | grep -nE "$pattern" 2>/dev/null)
        if [ -n "$matches" ]; then
            echo -e "${RED}BLOCKED:${NC} Potential secret in ${YELLOW}$file${NC}"
            echo "$matches" | head -3 | while read -r line; do
                echo "  -> line $line"
            done
            found=1
        fi
    done
done

if [ $found -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit blocked: sensitive data detected.${NC}"
    echo "If this is a false positive, use: git commit --no-verify"
    exit 1
fi

exit 0
